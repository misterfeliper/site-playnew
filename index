    <style>
        :root {
            --primary: #2196F3;
            --primary-dark: #1976D2;
            --primary-light: #64B5F6;
            --secondary: #42A5F5;
            --accent: #29B6F6;
            --blue-light: #90CAF9;
            --blue-dark: #1565C0;
            --cyan: #00BCD4;
            --teal: #009688;
            --dark: #121212;
            --dark-light: #1E1E1E;
            --darker: #0A0A0A;
            --light: #FFFFFF;
            --gray: #9E9E9E;
            --success: #4CAF50;
            --warning: #FF9800;
            --danger: #F44336;
            --card-bg: rgba(25, 118, 210, 0.1);
            --card-border: rgba(33, 150, 243, 0.3);
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Roboto', sans-serif;
            line-height: 1.6;
            color: var(--light);
            background-color: var(--dark);
            min-height: 100vh;
            overflow-x: hidden;
        }
        
        #particles-js {
            position: fixed;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            z-index: -1;
            opacity: 0.5;
        }
        
        .container {
            width: 100%;
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 20px;
            position: relative;
            z-index: 1;
        }
        
        /* Header */
        header {
            background-color: rgba(18, 18, 18, 0.98);
            padding: 15px 0;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
            border-bottom: 3px solid var(--primary);
            backdrop-filter: blur(10px);
        }
        
        .header-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .logo {
            display: flex;
            align-items: center;
            gap: 15px;
            text-decoration: none;
        }
        
        .logo-icon {
            color: var(--primary);
            font-size: 2.8rem;
        }
        
        .logo-text h1 {
            font-family: 'Poppins', sans-serif;
            font-weight: 800;
            font-size: 2rem;
            color: var(--light);
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }
        
        .logo-text p {
            font-size: 0.95rem;
            color: var(--gray);
        }
        
        /* Menu Desktop - NOVO DESIGN SIMPLIFICADO */
        .desktop-menu {
            display: flex;
            align-items: center;
            gap: 25px;
        }
        
        .desktop-menu ul {
            display: flex;
            list-style: none;
            gap: 25px;
            align-items: center;
        }
        
        .desktop-menu a {
            color: var(--light);
            text-decoration: none;
            font-weight: 500;
            font-size: 1.1rem;
            transition: all 0.3s;
            padding: 10px 15px;
            border-radius: 8px;
        }
        
        .desktop-menu a:hover {
            color: var(--primary);
            background-color: rgba(33, 150, 243, 0.1);
        }
        
        .desktop-menu a.active {
            color: var(--primary);
            background-color: rgba(33, 150, 243, 0.15);
            font-weight: 600;
        }
        
        .discord-menu-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            background: linear-gradient(135deg, #7289DA, #5B6EA6);
            color: white;
            text-decoration: none;
            padding: 12px 25px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 1rem;
            transition: all 0.3s;
            white-space: nowrap;
        }
        
        .discord-menu-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(114, 137, 218, 0.4);
        }
        
        .status-menu-btn {
            background: none;
            border: none;
            color: var(--light);
            font-size: 1.1rem;
            cursor: pointer;
            padding: 10px 15px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
        }
        
        .status-menu-btn:hover {
            color: var(--primary);
            background-color: rgba(33, 150, 243, 0.1);
        }
        
        .status-indicator-small {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background-color: var(--gray);
        }
        
        .status-indicator-small.online {
            background-color: var(--success);
            box-shadow: 0 0 10px var(--success);
        }
        
        /* Menu Mobile */
        .mobile-menu-btn {
            display: none;
            background: none;
            border: none;
            color: var(--light);
            font-size: 1.8rem;
            cursor: pointer;
            z-index: 1001;
        }
        
        .mobile-menu {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100vh;
            background-color: rgba(10, 10, 10, 0.98);
            z-index: 999;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(20px);
        }
        
        .mobile-menu.active {
            display: flex;
        }
        
        .mobile-menu ul {
            list-style: none;
            text-align: center;
            width: 100%;
            max-width: 500px;
            padding: 0 20px;
        }
        
        .mobile-menu li {
            margin: 15px 0;
        }
        
        .mobile-menu a, .mobile-menu .mobile-status-btn {
            color: var(--light);
            text-decoration: none;
            font-size: 1.5rem;
            font-weight: 500;
            transition: all 0.3s;
            display: block;
            padding: 20px 30px;
            border-radius: 15px;
            width: 100%;
            border: none;
            background: none;
            cursor: pointer;
            text-align: center;
        }
        
        .mobile-menu a:hover, .mobile-menu .mobile-status-btn:hover {
            background-color: rgba(33, 150, 243, 0.1);
            color: var(--primary);
        }
        
        .mobile-menu a.active {
            background-color: rgba(33, 150, 243, 0.2);
            color: var(--primary);
            border-left: 4px solid var(--primary);
        }
        
        .mobile-discord-btn {
            background: linear-gradient(135deg, #7289DA, #5B6EA6);
            color: white;
            margin-top: 30px;
            padding: 20px 40px;
            border-radius: 15px;
            font-size: 1.5rem;
