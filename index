        }
        
        .vip-card.blue1 .vip-image i {
            color: var(--primary-light);
        }
        
        .vip-card.blue2 .vip-image {
            background-color: rgba(33, 150, 243, 0.2);
            border-color: var(--primary);
        }
        
        .vip-card.blue2 .vip-image i {
            color: var(--primary);
        }
        
        .vip-card.blue3 .vip-image {
            background-color: rgba(0, 188, 212, 0.2);
            border-color: var(--cyan);
        }
        
        .vip-card.blue3 .vip-image i {
            color: var(--cyan);
        }
        
        .vip-title {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 20px;
            font-family: 'Poppins', sans-serif;
            text-shadow: 0 2px 10px rgba(0,0,0,0.3);
        }
        
        .vip-price {
