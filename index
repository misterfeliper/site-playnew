    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
    <script>
        // ============================
        // CONFIGURAÇÕES DO SITE
        // ============================
        const CONFIG = {
            SERVER_IP: "jogar.playnew.online",
            SERVER_PORT: 12304,
            CURRENT_YEAR: new Date().getFullYear(),
            DISCORD_ID: "1404104617595502662",
            STATUS_API: "https://api.mcsrvstat.us/2/",
            CACHE_ENABLED: true,
            CACHE_TTL: 30000
        };
        
        // ============================
        // ELEMENTOS DOM
        // ============================
        const elements = {
            notification: document.getElementById('notification'),
            notificationText: document.getElementById('notification-text'),
            serverIpDisplay: document.getElementById('serverIpDisplay'),
            copyIpBtn: document.getElementById('copyIpBtn'),
            statusIndicator: document.getElementById('statusIndicator'),
            statusIndicatorSmall: document.getElementById('statusIndicatorSmall'),
            statusText: document.getElementById('statusText'),
            serverStatusBadge: document.getElementById('serverStatusBadge'),
            footerStatus: document.getElementById('footerStatus'),
            statusBtn: document.getElementById('statusBtn'),
            mobileStatusBtn: document.getElementById('mobileStatusBtn'),
            statusModal: document.getElementById('statusModal'),
            closeModal: document.getElementById('closeModal'),
            statusModalContent: document.getElementById('statusModalContent'),
            customServerInput: document.getElementById('customServerInput'),
            checkServerBtn: document.getElementById('checkServerBtn'),
            mobileMenuBtn: document.getElementById('mobileMenuBtn'),
            closeMenuBtn: document.getElementById('closeMenuBtn'),
            mobileMenu: document.getElementById('mobileMenu'),
            playerCountFooter: document.getElementById('playerCountFooter'),
            serverUptime: document.getElementById('serverUptime'),
            lastUpdate: document.getElementById('lastUpdate'),
            currentYear: document.getElementById('currentYear'),
            scrollTopBtn: document.getElementById('scrollTopBtn')
        };
        
        // ============================
        // ESTADO DA APLICAÇÃO
        // ============================
        const appState = {
            serverStatus: null,
            lastUpdate: null,
            isChecking: false,
            currentServer: `${CONFIG.SERVER_IP}:${CONFIG.SERVER_PORT}`,
            serverStartTime: null,
            cache: {},
            lastCacheTime: {}
        };
        
        // ============================
        // INICIALIZAÇÃO
        // ============================
        function init() {
            initParticles();
            initCurrentYear();
            initEventListeners();
            initStatusSystem();
            initScrollTop();
        }
        
        // ============================
        // PARTÍCULAS BACKGROUND
        // ============================
        function initParticles() {
            particlesJS('particles-js', {
                particles: {
                    number: { value: 80, density: { enable: true, value_area: 800 } },
                    color: { value: ['#2196F3', '#64B5F6', '#90CAF9', '#00BCD4'] },
                    shape: { type: 'circle' },
                    opacity: { value: 0.5, random: true, anim: { enable: true, speed: 1, opacity_min: 0.1 } },
                    size: { value: 3, random: true, anim: { enable: true, speed: 2, size_min: 0.1 } },
                    line_linked: { enable: true, distance: 150, color: '#64B5F6', opacity: 0.2, width: 1 },
                    move: { enable: true, speed: 1, direction: 'none', random: true, straight: false }
                },
                interactivity: {
                    detect_on: 'canvas',
                    events: {
                        onhover: { enable: true, mode: 'grab' },
                        onclick: { enable: true, mode: 'push' }
                    }
                },
                retina_detect: true
            });
        }
        
        // ============================
        // SISTEMA DE STATUS
        // ============================
        function initStatusSystem() {
            // Verificar status inicial
            checkServerStatus(appState.currentServer);
            
            // Atualizar a cada 30 segundos
            setInterval(() => {
                checkServerStatus(appState.currentServer);
            }, 30000);
            
            // Atualizar tempo de uptime a cada segundo
            setInterval(updateUptime, 1000);
        }
        
        async function checkServerStatus(serverAddress = null) {
            const address = serverAddress || appState.currentServer;
            
            if (appState.isChecking) return;
            
            // Verificar cache
            const cacheKey = address;
            const now = Date.now();
            if (CONFIG.CACHE_ENABLED && 
                appState.cache[cacheKey] && 
                appState.lastCacheTime[cacheKey] && 
                (now - appState.lastCacheTime[cacheKey]) < CONFIG.CACHE_TTL) {
                
                const cachedData = appState.cache[cacheKey];
                appState.serverStatus = cachedData;
                appState.lastUpdate = new Date();
                appState.currentServer = address;
                
                updateStatusUI(cachedData);
                
                if (elements.statusModal.classList.contains('active')) {
                    updateStatusModalContent(cachedData, address);
                }
                
                return;
            }
            
            appState.isChecking = true;
            updateUIForLoading();
            
            try {
                const apiUrl = `${CONFIG.STATUS_API}${address}`;
                
                const response = await fetch(apiUrl, {
                    headers: {
                        'Accept': 'application/json',
                        'User-Agent': 'PlayNew Status Checker'
                    },
                    mode: 'cors'
                });
                
                if (!response.ok) {
                    throw new Error(`Erro HTTP: ${response.status}`);
                }
                
                const data = await response.json();
                
                // Adicionar timestamp
                data.timestamp = new Date().toISOString();
                
                // Cache dos dados
                if (CONFIG.CACHE_ENABLED) {
                    appState.cache[cacheKey] = data;
                    appState.lastCacheTime[cacheKey] = now;
                }
                
                appState.serverStatus = data;
                appState.lastUpdate = new Date();
                appState.currentServer = address;
                
                // Se for o primeiro status online, registrar o tempo
                if (data.online && !appState.serverStartTime) {
                    appState.serverStartTime = new Date();
                } else if (!data.online) {
                    appState.serverStartTime = null;
                }
                
                updateStatusUI(data);
                
                if (elements.statusModal.classList.contains('active')) {
                    updateStatusModalContent(data, address);
                }
                
            } catch (error) {
                console.error('Erro ao verificar status:', error);
                
                // Servidor offline ou erro na conexão
                const data = {
                    online: false,
                    timestamp: new Date().toISOString(),
                    error: error.message
                };
                
                appState.serverStatus = data;
                appState.lastUpdate = new Date();
                appState.serverStartTime = null;
                
                setServerOffline();
                
                if (elements.statusModal.classList.contains('active')) {
                    updateStatusModalContent(data, address);
                }
            } finally {
                appState.isChecking = false;
            }
        }
        
        function updateUIForLoading() {
            elements.statusIndicator.className = 'status-indicator';
            elements.statusIndicatorSmall.className = 'status-indicator-small';
            elements.statusText.textContent = 'Verificando...';
            elements.footerStatus.textContent = 'Verificando...';
        }
        
        function updateStatusUI(data) {
            if (data.online) {
                const players = data.players?.online || 0;
                const maxPlayers = data.players?.max || 0;
                
                elements.statusIndicator.className = 'status-indicator online';
                elements.statusIndicatorSmall.className = 'status-indicator-small online';
                elements.statusText.textContent = `ONLINE (${players}/${maxPlayers} jogadores)`;
                elements.footerStatus.textContent = `ONLINE (${players}/${maxPlayers})`;
                elements.playerCountFooter.textContent = players;
                
                const now = new Date();
                elements.lastUpdate.textContent = now.toLocaleTimeString('pt-BR', {
                    hour: '2-digit',
                    minute: '2-digit'
                });
            } else {
                setServerOffline();
            }
        }
        
        function setServerOffline() {
            elements.statusIndicator.className = 'status-indicator';
            elements.statusIndicatorSmall.className = 'status-indicator-small';
            elements.statusText.textContent = 'OFFLINE';
            elements.footerStatus.textContent = 'OFFLINE';
            elements.playerCountFooter.textContent = '0';
        }
        
        function updateUptime() {
            if (appState.serverStartTime) {
                const now = new Date();
                const diff = Math.floor((now - appState.serverStartTime) / 1000);
                
                if (diff < 60) {
                    elements.serverUptime.textContent = `${diff}s`;
                } else if (diff < 3600) {
                    const minutes = Math.floor(diff / 60);
                    const seconds = diff % 60;
                    elements.serverUptime.textContent = `${minutes}m ${seconds}s`;
                } else if (diff < 86400) {
                    const hours = Math.floor(diff / 3600);
                    const minutes = Math.floor((diff % 3600) / 60);
                    elements.serverUptime.textContent = `${hours}h ${minutes}m`;
                } else {
                    const days = Math.floor(diff / 86400);
                    const hours = Math.floor((diff % 86400) / 3600);
                    elements.serverUptime.textContent = `${days}d ${hours}h`;
                }
            } else {
                elements.serverUptime.textContent = '--';
            }
        }
        
        function updateStatusModalContent(data, serverAddress) {
            const isOnline = data.online;
            const players = data.players?.online || 0;
            const maxPlayers = data.players?.max || 0;
            const version = data.version || 'Desconhecida';
            
            // Extrair MOTD
            let motd = 'Sem descrição';
            if (data.motd) {
                if (data.motd.clean) {
                    motd = Array.isArray(data.motd.clean) ? data.motd.clean.join(' ') : data.motd.clean;
                } else if (typeof data.motd === 'string') {
                    motd = data.motd;
                }
            }
            
            // Lista de jogadores
            let playersList = [];
            if (data.players && data.players.list) {
                playersList = data.players.list;
            }
            
            let playersHTML = '';
            
            if (isOnline && players > 0) {
                if (playersList.length > 0) {
                    // Mostrar jogadores reais
                    playersHTML = playersList.map(player => `
                        <div class="player-card">
                            <div class="player-head-modal">
                                <img src="https://mc-heads.net/avatar/${player}/80" alt="${player}">
                            </div>
                            <span>${player}</span>
                        </div>
                    `).join('');
                    
                    if (players > playersList.length) {
                        playersHTML += `
                            <div class="player-card" style="grid-column: span 2;">
                                <div style="font-size: 2rem; color: var(--primary); margin-bottom: 10px;">
                                    <i class="fas fa-users"></i>
                                </div>
                                <span>E mais ${players - playersList.length} jogadores...</span>
                            </div>
                        `;
                    }
                } else {
                    // Lista de jogadores não disponível
                    playersHTML = `
                        <div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: var(--light);">
                            <i class="fas fa-users" style="font-size: 3rem; color: var(--primary); margin-bottom: 20px;"></i>
                            <p style="font-size: 1.3rem; margin-bottom: 10px;">${players} jogadores online</p>
                            <p style="color: var(--gray);">A lista de jogadores não está disponível</p>
                        </div>
                    `;
                }
            } else if (isOnline) {
                playersHTML = `
                    <div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: var(--gray);">
                        <i class="fas fa-user-slash" style="font-size: 3rem; margin-bottom: 20px;"></i>
                        <p>Nenhum jogador online no momento</p>
                    </div>
                `;
            }
            
            elements.statusModalContent.innerHTML = `
                <div class="status-details-grid">
                    <div class="status-item">
                        <div class="label">Status</div>
                        <div class="value ${isOnline ? 'online' : 'offline'}">${isOnline ? 'ONLINE' : 'OFFLINE'}</div>
                    </div>
                    <div class="status-item">
                        <div class="label">Jogadores</div>
                        <div class="value">${players}/${maxPlayers}</div>
                    </div>
                    <div class="status-item">
                        <div class="label">Versão</div>
                        <div class="value">${version}</div>
                    </div>
                    <div class="status-item" style="width: 875px;">
                        <div class="label">IP do Servidor</div>
                        <div class="value">${serverAddress}</div>
                    </div>
                </div>
                
                ${isOnline ? `
                    <div style="margin: 30px 0; padding: 25px; background-color: rgba(0,0,0,0.2); border-radius: 15px; border-left: 4px solid var(--primary);">
			<p style="font-size: 30px;">MOTD</p>
                        <p style="color: var(--gray); font-style: italic; margin: 0; font-size: 1.1rem;">"${motd}"</p>
                    </div>
                ` : `
                    <div style="margin: 30px 0; padding: 40px; text-align: center; background-color: rgba(244, 67, 54, 0.1); border-radius: 15px; border-left: 4px solid var(--danger);">
                        <i class="fas fa-exclamation-triangle" style="font-size: 3rem; color: var(--danger); margin-bottom: 20px;"></i>
                        <p style="color: var(--light); font-weight: 500; font-size: 1.2rem;">Servidor offline ou não encontrado</p>
                        <p style="color: var(--gray); margin-top: 10px;">Verifique o IP e porta e tente novamente</p>
                    </div>
                `}
                
                <div class="players-section">
                    <h4><i class="fas fa-users"></i> Jogadores Online (${players})</h4>
                    <div class="players-grid">
                        ${playersHTML}
                    </div>
                </div>
                
                <div style="margin-top: 40px; text-align: center; display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;">
                    <button class="check-btn" id="refreshStatusBtn" style="padding: 15px 30px;">
                        <i class="fas fa-redo"></i> Atualizar Status
                    </button>
                    ${serverAddress !== `${CONFIG.SERVER_IP}:${CONFIG.SERVER_PORT}` ? `
                        <button class="check-btn" id="backToMainBtn" style="padding: 15px 30px; background: linear-gradient(135deg, var(--dark-light), #2a2a2a);">
                            <i class="fas fa-home"></i> Voltar ao Principal
                        </button>
                    ` : ''}
                    <button class="check-btn" id="copyServerIpBtn" style="padding: 15px 30px; background: linear-gradient(135deg, var(--primary), var(--primary-dark));">
                        <i class="fas fa-copy"></i> Copiar IP
                    </button>
                </div>
                
                <div style="margin-top: 30px; text-align: center; color: var(--gray); font-size: 0.95rem;">
                    <i class="fas fa-clock"></i> Última verificação: ${appState.lastUpdate ? appState.lastUpdate.toLocaleTimeString('pt-BR') : 'Nunca'}
                </div>
            `;
            
            document.getElementById('refreshStatusBtn')?.addEventListener('click', () => {
                delete appState.cache[serverAddress];
                delete appState.lastCacheTime[serverAddress];
                checkServerStatus(serverAddress);
            });
            
            document.getElementById('backToMainBtn')?.addEventListener('click', () => {
                elements.customServerInput.value = `${CONFIG.SERVER_IP}:${CONFIG.SERVER_PORT}`;
                checkServerStatus(`${CONFIG.SERVER_IP}:${CONFIG.SERVER_PORT}`);
            });
            
            document.getElementById('copyServerIpBtn')?.addEventListener('click', () => {
                copyToClipboard(serverAddress);
                showNotification(`IP copiado: ${serverAddress}`, 'success');
            });
        }
        
        // ============================
        // UTILITÁRIOS
        // ============================
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).catch(() => {
                const textarea = document.createElement('textarea');
                textarea.value = text;
                document.body.appendChild(textarea);
                textarea.select();
                document.execCommand('copy');
                document.body.removeChild(textarea);
            });
        }
        
        function showNotification(message, type = 'success') {
            elements.notificationText.textContent = message;
            elements.notification.className = `notification ${type}`;
            elements.notification.classList.add('show');
            
            setTimeout(() => {
                elements.notification.classList.remove('show');
            }, 3000);
        }
        
        function initCurrentYear() {
            elements.currentYear.textContent = CONFIG.CURRENT_YEAR;
        }
        
        function initScrollTop() {
            window.addEventListener('scroll', () => {
                if (window.scrollY > 500) {
                    elements.scrollTopBtn.classList.add('show');
                } else {
                    elements.scrollTopBtn.classList.remove('show');
                }
            });
            
            elements.scrollTopBtn.addEventListener('click', () => {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });
        }
        
        // ============================
        // EVENT LISTENERS
        // ============================
        function initEventListeners() {
            // Copiar IP
            elements.copyIpBtn.addEventListener('click', () => {
                copyToClipboard(`${CONFIG.SERVER_IP}:${CONFIG.SERVER_PORT}`);
                showNotification('IP copiado com sucesso!', 'success');
            });
            
            // Status modal
            elements.statusBtn.addEventListener('click', openStatusModal);
            elements.mobileStatusBtn.addEventListener('click', openStatusModal);
            elements.serverStatusBadge.addEventListener('click', openStatusModal);
            elements.closeModal.addEventListener('click', closeStatusModal);
            
            // Menu mobile
            elements.mobileMenuBtn.addEventListener('click', openMobileMenu);
            elements.closeMenuBtn.addEventListener('click', closeMobileMenu);
            
            // Verificar servidor personalizado
            elements.checkServerBtn.addEventListener('click', checkCustomServer);
            elements.customServerInput.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') {
                    checkCustomServer();
                }
            });
            
            // Fechar modal ao clicar fora
            elements.statusModal.addEventListener('click', (e) => {
                if (e.target === elements.statusModal) {
                    closeStatusModal();
                }
            });
            
            // Fechar menu mobile ao clicar em um link
            document.querySelectorAll('.mobile-menu a').forEach(link => {
                link.addEventListener('click', closeMobileMenu);
            });
            
            // Links do menu mobile (status)
            document.getElementById('mobileStatusBtn').addEventListener('click', (e) => {
                e.preventDefault();
                openStatusModal();
                closeMobileMenu();
            });
            
            setupSmoothScrolling();
        }
        
        async function checkCustomServer() {
            const input = elements.customServerInput.value.trim();
            if (!input) return;
            
            showNotification(`Verificando status de ${input}...`, 'info');
            
            delete appState.cache[input];
            delete appState.lastCacheTime[input];
            
            await checkServerStatus(input);
        }
        
        function openMobileMenu() {
            elements.mobileMenu.classList.add('active');
            document.body.style.overflow = 'hidden';
        }
        
        function closeMobileMenu() {
            elements.mobileMenu.classList.remove('active');
            document.body.style.overflow = 'auto';
        }
        
        function openStatusModal() {
            elements.statusModal.classList.add('active');
            document.body.style.overflow = 'hidden';
            
            if (!appState.serverStatus) {
                checkServerStatus(appState.currentServer);
            } else {
                updateStatusModalContent(appState.serverStatus, appState.currentServer);
            }
        }
        
        function closeStatusModal() {
            elements.statusModal.classList.remove('active');
            document.body.style.overflow = 'auto';
        }
        
        function setupSmoothScrolling() {
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function(e) {
                    const href = this.getAttribute('href');
                    
                    if (href === '#') {
                        e.preventDefault();
                        return;
                    }
                    
                    if (href === '#home') {
                        e.preventDefault();
                        window.scrollTo({
                            top: 0,
                            behavior: 'smooth'
                        });
                        return;
                    }
                    
                    const targetElement = document.querySelector(href);
                    if (targetElement) {
                        e.preventDefault();
                        const headerHeight = document.querySelector('header').offsetHeight;
                        const targetPosition = targetElement.offsetTop - headerHeight - 20;
                        
                        window.scrollTo({
                            top: targetPosition,
                            behavior: 'smooth'
                        });
                        
                        updateActiveNav(href);
                    }
                });
            });
            
            window.addEventListener('scroll', updateActiveNavOnScroll);
        }
        
        function updateActiveNav(href) {
            document.querySelectorAll('.desktop-menu a').forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href') === href) {
                    link.classList.add('active');
                }
            });
            
            document.querySelectorAll('.mobile-menu a').forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href') === href) {
                    link.classList.add('active');
                }
            });
        }
        
        function updateActiveNavOnScroll() {
            const sections = document.querySelectorAll('section[id]');
            let current = '';
            
            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                const sectionHeight = section.clientHeight;
                const headerHeight = document.querySelector('header').offsetHeight;
                
                if (scrollY >= (sectionTop - headerHeight - 100)) {
                    current = section.getAttribute('id');
                }
            });
            
            if (current) {
                updateActiveNav(`#${current}`);
            }
        }
        
        window.addEventListener('DOMContentLoaded', init);
    </script>
</body>
</html>
