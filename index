            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 100%;
            height: 3px;
            background: linear-gradient(90deg, var(--primary), transparent);
        }
        
        .hero-subtitle {
            font-size: 1.5rem;
            max-width: 900px;
            margin: 0 auto 40px;
            color: var(--gray);
            line-height: 1.8;
        }
        
        .server-ip-container {
            background-color: var(--card-bg);
            padding: 40px;
            border-radius: 20px;
            display: inline-block;
            margin: 40px 0;
            border: 3px solid var(--primary);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(10px);
            position: relative;
            overflow: hidden;
        }
        
        .server-ip-container::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(33, 150, 243, 0.1), transparent);
            transform: rotate(45deg);
        }
        
        .server-ip-container h3 {
            color: var(--light);
            margin-bottom: 25px;
            font-size: 1.8rem;
            position: relative;
        }
        
        .server-ip-display {
            font-family: 'Roboto Mono', monospace;
            font-size: 2.5rem;
            font-weight: bold;
            color: var(--primary);
            background-color: rgba(0, 0, 0, 0.5);
            padding: 20px 50px;
            border-radius: 15px;
            letter-spacing: 2px;
            border: 3px solid var(--primary-dark);
            margin-bottom: 25px;
            display: inline-block;
            position: relative;
            overflow: hidden;
        }
        
        .server-ip-display::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
            animation: shimmer 3s infinite;
        }
        
        @keyframes shimmer {
            0% { left: -100%; }
            100% { left: 100%; }
        }
        
        .copy-ip-btn {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: var(--light);
            border: none;
            padding: 15px 40px;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 0 auto;
            position: relative;
            overflow: hidden;
        }
        
        .copy-ip-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(33, 150, 243, 0.4);
        }
        
        .server-status-badge {
            display: inline-flex;
            align-items: center;
            gap: 15px;
            background-color: rgba(30, 30, 30, 0.9);
            padding: 20px 35px;
            border-radius: 50px;
            margin-top: 30px;
            border: 2px solid var(--dark-light);
            cursor: pointer;
            transition: all 0.3s;
            backdrop-filter: blur(5px);
        }
        
        .server-status-badge:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            border-color: var(--primary);
        }
        
        .status-indicator {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background-color: var(--gray);
            position: relative;
        }
        
        .status-indicator.online {
            background-color: var(--success);
            box-shadow: 0 0 20px var(--success);
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0% { 
                box-shadow: 0 0 0 0 rgba(76, 175, 80, 0.7);
            }
            70% { 
                box-shadow: 0 0 0 15px rgba(76, 175, 80, 0);
            }
            100% { 
                box-shadow: 0 0 0 0 rgba(76, 175, 80, 0);
            }
        }
        
        /* Section Common Styles */
        section {
            padding: 100px 0;
        }
        
        .section-title {
            text-align: center;
            margin-bottom: 60px;
            position: relative;
        }
        
        .section-title h2 {
            font-family: 'Poppins', sans-serif;
            font-size: 3rem;
            color: var(--light);
            margin-bottom: 20px;
            display: inline-block;
            position: relative;
        }
        
        .section-title h2::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: 4px;
            background: linear-gradient(90deg, var(--primary), var(--cyan));
            border-radius: 2px;
        }
        
        .section-title p {
            color: var(--gray);
            max-width: 800px;
            margin: 0 auto;
            font-size: 1.2rem;
            line-height: 1.8;
        }
        
        /* Server Info Section */
        .server-info {
            background: linear-gradient(to bottom, rgba(18, 18, 18, 0.8), rgba(21, 101, 192, 0.2));
        }
        
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 35px;
            margin-top: 40px;
        }
        
        .feature-card {
            background-color: var(--card-bg);
            padding: 40px 35px;
            border-radius: 20px;
            text-align: center;
            transition: all 0.4s;
            border: 2px solid transparent;
            backdrop-filter: blur(5px);
            position: relative;
            overflow: hidden;
        }
        
        .feature-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--cyan), var(--teal));
        }
        
        .feature-card:hover {
            transform: translateY(-15px) scale(1.02);
            border-color: var(--cyan);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4);
        }
        
        .feature-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto 25px;
            background: linear-gradient(135deg, rgba(0, 188, 212, 0.2), rgba(33, 150, 243, 0.1));
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            color: var(--cyan);
        }
        
        .feature-card h3 {
            font-size: 1.7rem;
            margin-bottom: 20px;
            color: var(--light);
        }
        
        .feature-card p {
            color: var(--gray);
            line-height: 1.8;
            font-size: 1.1rem;
        }
        
        /* Team Section */
        .team-section {
            background: linear-gradient(to bottom, rgba(10, 10, 10, 0.9), rgba(21, 101, 192, 0.3));
        }
        
        .team-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 35px;
            margin-top: 60px;
        }
        
        .team-card {
            background-color: var(--card-bg);
            padding: 40px 35px;
            border-radius: 20px;
            text-align: center;
            transition: all 0.4s;
            border: 2px solid transparent;
            backdrop-filter: blur(5px);
            position: relative;
            overflow: hidden;
        }
        
        .team-card:hover {
            transform: translateY(-10px);
            border-color: var(--primary);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        }
        
        .player-head {
            width: 140px;
            height: 140px;
            margin: 0 auto 30px;
            border-radius: 20px;
            overflow: hidden;
            border: 4px solid var(--primary);
            background-color: #2a2a2a;
            transition: all 0.3s;
            position: relative;
        }
        
        .team-card:hover .player-head {
            transform: rotate(5deg) scale(1.05);
            box-shadow: 0 10px 30px rgba(33, 150, 243, 0.3);
        }
        
        .player-head img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            image-rendering: pixelated;
            transition: all 0.3s;
        }
        
        .team-card:hover .player-head img {
            transform: scale(1.1);
        }
        
        .team-card h3 {
            font-size: 1.8rem;
            margin-bottom: 15px;
            color: var(--light);
        }
        
        .team-card .role {
            color: var(--primary);
            font-weight: 600;
            margin-bottom: 25px;
            display: block;
            font-size: 1.2rem;
            padding: 8px 20px;
            background-color: rgba(33, 150, 243, 0.1);
            border-radius: 20px;
            display: inline-block;
        }
        
        /* Store Section */
        .store-section {
            background: linear-gradient(to bottom, rgba(25, 118, 210, 0.3), rgba(10, 10, 10, 0.9));
        }
        
        .store-intro {
            text-align: center;
            max-width: 900px;
            margin: 0 auto 60px;
        }
        
        .store-intro p {
            color: var(--gray);
            font-size: 1.3rem;
            line-height: 1.8;
        }
        
        .vip-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
            gap: 40px;
            margin-top: 40px;
        }
        
        .vip-card {
            background-color: var(--card-bg);
            border-radius: 25px;
            overflow: hidden;
            transition: all 0.4s;
            border: 3px solid transparent;
            position: relative;
            backdrop-filter: blur(5px);
        }
        
        .vip-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4);
        }
        
        .vip-card.blue1 {
            border-color: var(--primary-light);
        }
        
        .vip-card.blue1 .vip-header {
            background: linear-gradient(135deg, var(--primary-light), var(--primary));
        }
        
        .vip-card.blue2 {
            border-color: var(--primary);
        }
        
        .vip-card.blue2 .vip-header {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        }
        
        .vip-card.blue3 {
            border-color: var(--cyan);
        }
        
        .vip-card.blue3 .vip-header {
            background: linear-gradient(135deg, var(--cyan), var(--teal));
        }
        
        .vip-header {
            padding: 50px 40px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        
        .vip-header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);
        }
        
        .vip-image {
            width: 120px;
            height: 120px;
            margin: 0 auto 25px;
