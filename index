            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            width: 100%;
            max-width: 500px;
            text-decoration: none;
            transition: all 0.3s;
        }
        
        .mobile-discord-btn:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(114, 137, 218, 0.4);
        }
        
        .close-menu {
            position: absolute;
            top: 25px;
            right: 25px;
            background: none;
            border: none;
            color: var(--light);
            font-size: 2.5rem;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .close-menu:hover {
            color: var(--primary);
            transform: rotate(90deg);
        }
        
        /* Hero Section */
        .hero {
            padding: 150px 0 100px;
            text-align: center;
            position: relative;
            background: linear-gradient(135deg, rgba(10, 10, 10, 0.8) 0%, rgba(21, 101, 192, 0.3) 100%);
